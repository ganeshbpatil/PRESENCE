# PRESENCE — environment template. Copy to .env, never commit .env itself.

# --- Core ---
ENVIRONMENT=development
PRESENCE_API_DOMAIN=api.presence.yourdomain.com
SECRET_KEY=change-me

# --- Database ---
POSTGRES_DB=presence
POSTGRES_USER=presence
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+asyncpg://presence:@postgres:5432/presence

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AI Orchestrator ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_PROVIDER=openrouter
AI_CACHE_TTL_SECONDS=86400

# --- WhatsApp BSP (Gallabox primary) ---
GALLABOX_API_KEY=
GALLABOX_API_SECRET=
GALLABOX_WEBHOOK_SECRET=
# Uncomment when/if a second BSP is added per the abstraction layer:
# GUPSHUP_API_KEY=
# INTERAKT_API_KEY=

# --- Google Business Profile (OAuth scaffold only -- see
# services/sync-engine/adapters/social/gbp.py and gateway/api/v1/oauth.py;
# the real token exchange isn't wired up yet, these just gate whether
# /api/v1/oauth/status reports "configured") ---
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
GBP_REDIRECT_URI=

# --- Meta Business Suite (OAuth scaffold only, same caveat as GBP above) ---
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_REDIRECT_URI=

# --- Billing ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- JWT / Auth ---
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=30

# --- Notifications (email channel) ---
# Left blank in dev/staging -> notifications service logs instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@presence.yourdomain.com

# --- Vault (platform access token storage, SECURITY_ARCHITECTURE.md) ---
# VAULT_ROLE_ID/VAULT_SECRET_ID come from the one-time `scripts/vault-init.sh`
# run by hand on the VPS -- never generated or stored by app code/CI.
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_KV_MOUNT=presence-secrets

# --- Admin panel frontend (CORS) ---
# Comma-separated origins, e.g. http://localhost:3000,https://app.presence.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Signup gate ---
# Required to create a Business or Agency (both are otherwise-unauthenticated
# bootstrap endpoints). Empty skips the check entirely -- set this in
# production. Distribute this one code to whoever should be able to onboard
# an agency/business; rotate by changing this value.
SIGNUP_INVITE_CODE=

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO
